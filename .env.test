# Test Environment Configuration
NODE_ENV=test
LOG_LEVEL=error
# Server
PORT=3001
# Database - SEPARATE TEST DATABASE
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fx_trading_test
DATABASE_SYNC=true
LOG_LEVEL=error
# Redis - Can use same instance but different DB number
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
# JWT - Test secrets
JWT_SECRET=test-jwt-secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=test-refresh-jwt-secret
JWT_REFRESH_EXPIRATION=7d
# Password Reset
PASSWORD_RESET_TOKEN_EXPIRATION_SEC=600
PASSWORD_RESET_TOKEN_LENGTH=6
# OTP
OTP_EXPIRATION_SEC=600
OTP_LENGTH=6
# FX Rate API - Will be mocked in tests
FX_RATE_API_URL=https://test.v6.exchangerate-api.com/v6
FX_RATE_API_KEY=test-api-key
FX_RATE_CACHE_TTL_SEC=300
# Email - Mocked in tests
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=test-password
EMAIL_FROM=noreply@test.com
# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=1000
